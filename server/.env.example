# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Server Port (Defaults to 5001)
PORT=5001

# Firebase Configuration (Optional - Falls back to local JSON database if blank)
# Paste your entire Firebase Service Account JSON single-line string here:
FIREBASE_SERVICE_ACCOUNT_JSON=

# Or specify the path to your service account JSON file:
GOOGLE_APPLICATION_CREDENTIALS=
